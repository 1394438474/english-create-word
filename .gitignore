backend/.mvn/wrapper/maven-wrapper.jar
backend/app.out.log
backend/app.err.log
backend/logs/

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo

# ---------- 前端 (Vue3 / Vite) ----------
