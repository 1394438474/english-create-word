__pycache__/
*.py[cod]
*.pyo
*.egg-info/
scripts/data/
.venv/
venv/

# ---------- 通用 ----------
*.log
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db

# 环境变量 / 凭据
.env
.env.local
*.pem
